# Your ChatGPT session tokens (split into 2 cookies)
# Get from browser: F12 -> Application -> Cookies -> chatgpt.com
# Copy the value of __Secure-next-auth.session-token.0
SESSION_TOKEN_0=your-token-part-0-here
# Copy the value of __Secure-next-auth.session-token.1
SESSION_TOKEN_1=your-token-part-1-here

# Codex backend endpoint
CODEX_API=https://chatgpt.com/backend-api

# Logging
LOG_FILE=./logs/codex-ping.log

# Quota retry behavior. Keep WAIT_ON_QUOTA=false on GitHub Actions so runners do not sleep.
WAIT_ON_QUOTA=false
QUOTA_RETRY_BUFFER_MS=120000
QUOTA_MAX_WAIT_MS=21600000
